# ── Server ───────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
APP_NAME=Kynettic API

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=kynettic
DB_PASSWORD=kynettic123
DB_NAME=kynettic
DB_SSLMODE=disable
DB_AUTO_MIGRATE=true

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=dev_jwt_secret_please_replace_with_long_random_value_123456
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=dev_refresh_secret_please_replace_with_long_random_value_654321
JWT_REFRESH_EXPIRATION=168h
JWT_PREVIOUS_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION=1m

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=console

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=Kynettic <onboarding@resend.dev>

# ── KYC Encryption ───────────────────────────────────────────────────────────
# Both keys must be at least 32 characters of high-entropy.
# Generate with: openssl rand -hex 32
KYC_ENCRYPTION_KEY=dev_kyc_encryption_secret_key_please_replace_with_32_bytes
KYC_BLIND_INDEX_KEY=dev_kyc_blind_index_secret_key_please_replace_with_32_bytes

# ── PIN Security ──────────────────────────────────────────────────────────────
# Server-side HMAC pepper for PIN hashing — prevents offline brute-force.
# Generate with: openssl rand -hex 32
PIN_PEPPER=dev_pin_pepper_please_replace_with_long_random_value_1234567890

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Cloudinary (KYC document uploads) ────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=kyc

# ── CoinGecko (live market prices) ───────────────────────────────────────────
COINGECKO_API_KEY=
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# ── P2P Fee ───────────────────────────────────────────────────────────────────
P2P_FEE_PERCENT=0.2

# ── Telegram Bot (optional) ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=0
TELEGRAM_WEBHOOK_SECRET=
